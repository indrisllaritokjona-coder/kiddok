# Reminder settings
REMINDER_CHECK_CRON=0 8 * * *   # Daily at 8:00 AM (UTC)
REMINDER_VACCINE_DAYS_BEFORE=3  # Days before due date to remind
REMINDER_APPOINTMENT_HOURS_BEFORE=24 # Hours before appointment to remind