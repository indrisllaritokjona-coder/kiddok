generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  pin       String?
  name      String
  children  Child[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Child {
  id                 String         @id @default(uuid())
  name               String
  dateOfBirth        DateTime
  gender             String?
  bloodType          String?
  allergies          String?
  birthWeight        Float?
  deliveryDoctor     String?
  criticalAllergies  String?
  medicalDocument    String?        // base64 encoded document
  documentIssueDate  DateTime?
  medicalNotes       String?
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthRecords      HealthRecord[]
  vaccines           Vaccine[]
  temperatureEntries TemperatureEntry[]
  growthEntries       GrowthEntry[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model HealthRecord {
  id              String   @id @default(uuid())
  childId         String
  child           Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  type            String   // "ILLNESS", "CHECKUP", "SYMPTOM", "TEMP", "MEDICATION", "VACCINE"
  symptoms        String?
  diagnosis       String?
  medications     String?
  notes           String?
  attachments     String[]
  doctorName      String?
  // Temperature log fields
  temperature     Float?
  temperatureTime String?
  // Medication log fields
  medicationName   String?
  medicationDose   String?
  medicationTime   String?
  medicationEffectiveness String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Vaccine {
  id             String   @id @default(uuid())
  childId        String
  child          Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  name           String
  dateAdministered DateTime?
  dueDate        DateTime?
  provider       String?
  notes          String?
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TemperatureEntry {
  id          String   @id @default(uuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  temperature Float
  measuredAt  DateTime
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
}

model GrowthEntry {
  id         String   @id @default(uuid())
  childId    String
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  height     Float?
  weight     Float?
  measuredAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
}
