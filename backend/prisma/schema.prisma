generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  pin           String?
  name          String
  children      Child[]
  familyMembers FamilyMember[]
  shareLinks    ShareLink[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Child {
  id                 String         @id @default(uuid())
  name               String
  dateOfBirth        DateTime
  gender             String?
  bloodType          String?
  allergies          String?
  birthWeight        Float?
  deliveryDoctor     String?
  criticalAllergies  String?
  medicalDocument    String?
  documentIssueDate  DateTime?
  medicalNotes       String?
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthRecords      HealthRecord[]
  vaccines           Vaccine[]
  temperatureEntries TemperatureEntry[]
  growthEntries       GrowthEntry[]
  diaryEntries        DiaryEntry[]
  illnessEpisodes     IllnessEpisode[]
  medications          Medication[]
  familyMembers       FamilyMember[]
  shareLinks          ShareLink[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model HealthRecord {
  id              String   @id @default(uuid())
  childId         String
  child           Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  type            String   // "ILLNESS", "CHECKUP", "SYMPTOM", "TEMP", "MEDICATION", "VACCINE"
  symptoms        String?
  diagnosis       String?
  medications     String?
  notes           String?
  attachments     String[]
  doctorName      String?
  // Temperature log fields
  temperature     Float?
  temperatureTime String?
  // Medication log fields
  medicationName   String?
  medicationDose   String?
  medicationTime   String?
  medicationEffectiveness String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Vaccine {
  id             String   @id @default(uuid())
  childId        String
  child          Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  name           String
  dateAdministered DateTime?
  dueDate        DateTime?
  provider       String?
  notes          String?
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TemperatureEntry {
  id          String   @id @default(uuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  temperature Float
  measuredAt  DateTime
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
}

model GrowthEntry {
  id         String   @id @default(uuid())
  childId    String
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  height     Float?
  weight     Float?
  measuredAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
}

model DiaryEntry {
  id          String   @id @default(uuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  type        String   // symptom | meal | sleep | mood | activity
  description String?
  severity    String?  // mild | moderate | severe
  duration    String?
  loggedAt    DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ParentProfile {
  id        String   @id @default(uuid())
  name      String
  surname   String
  phone     String
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IllnessEpisode {
  id          String   @id @default(uuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  title       String
  symptoms    String?
  medications String?
  notes       String?
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Medication {
  id           String   @id @default(uuid())
  childId      String
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  name         String
  dosage       String
  frequency    String
  startDate    DateTime
  endDate      DateTime?
  prescribedBy  String?
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ShareLink {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  createdBy String
  creator   User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FamilyMember {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  childId  String
  child    Child  @relation(fields: [childId], references: [id], onDelete: Cascade)
  role     String // 'parent' | 'grandparent' | 'nanny' | 'doctor'

  @@unique([userId, childId])
}
