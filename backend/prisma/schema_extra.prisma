model Appointment {
  id         String   @id @default(uuid())
  childId    String
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  title      String
  doctorName String?
  location   String?
  dateTime   DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LabResult {
  id             String   @id @default(uuid())
  childId        String
  child          Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  testName       String
  result         String
  unit           String?
  referenceRange String?
  date           DateTime
  doctor         String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}